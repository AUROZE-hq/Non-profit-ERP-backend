# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=your_mongodb_connection_string_here
# OR MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/salary_system

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
# NOTE: Use Gmail App Password (not your real password)
# Go to: Google Account > Security > 2FA > App Passwords

# ─── Company Info (shown on salary slips) ─────────────────────────────────────
COMPANY_NAME=Your Company Ltd
COMPANY_ADDRESS=123 Business Street, City, Country
COMPANY_EMAIL=your_company_email@gmail.com
COMPANY_PHONE=+1 234 567 8900

# ─── App URL (used in signature links sent to employees) ──────────────────────
# APP_URL=http://localhost:3000
# BACKEND_URL=http://localhost:5000

# ─── Google Cloud Storage ─────────────────────────────────────────────────────
GCS_BUCKET_NAME=your-salary-slips-bucket
# Option A: Path to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./gcs-service-account.json
# Option B: Inline JSON (for deployment platforms like Railway/Render)
# GCS_KEY_JSON={"type":"service_account","project_id":"..."}